{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@hono/trpc-server": "^0.4.2",
    "@no-chat/api": "workspace:*",
    "@no-chat/auth": "workspace:*",
    "@no-chat/db": "workspace:*",
    "@no-chat/env": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "fastify": "^5.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@no-chat/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.5",
    "typescript": "^6"
  }
}
