		"@opaque/db": "workspace:*",
		"@opaque/env": "workspace:*",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"fastify": "^5.9.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@opaque/config": "workspace:*",
		"@types/node": "catalog:",
		"tsdown": "^0.22.3",
		"tsx": "^4.22.5",
		"typescript": "^6"
	}
